# ── Network ───────────────────────────────────────────────────────────────────
# "testnet"  → Ethereum Sepolia  (mock swaps, real x402 + a2a-pay)
# "base"     → Base Mainnet      (real everything, ~$0.01 gas) ← recommended
# "mainnet"  → Ethereum Mainnet  (real everything, higher gas)
NETWORK=base

# ── OKX API ───────────────────────────────────────────────────────────────────
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Agent Wallets ─────────────────────────────────────────────────────────────
# Fund both with ETH (gas) + USDC (entry fees) on Base
AGENT_A_WALLET_ADDRESS=0x...
AGENT_B_WALLET_ADDRESS=0x...

# ── Arena Escrow Wallet ───────────────────────────────────────────────────────
# Receives x402 entry fees — just a regular wallet you control
ARENA_ESCROW_WALLET=0x...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# ── Target Asset ──────────────────────────────────────────────────────────────
# Defaults are pre-filled per network in config.ts — only override if needed.
# Base WETH:           0x4200000000000000000000000000000000000006  (chainIndex 8453)
# Ethereum WETH:       0xc02aaa39b223fe8d0a0e5c4f27ead9083c756cc2 (chainIndex 1)
# Sepolia WETH:        0x7b79995e5f793a07bc00c21412e50ecae098e7f9 (chainIndex 11155111)
TARGET_ASSET_SYMBOL=ETH
# TARGET_CHAIN_INDEX=   ← auto-set from NETWORK, override only if needed
# TARGET_ASSET_CONTRACT= ← auto-set from NETWORK, override only if needed
